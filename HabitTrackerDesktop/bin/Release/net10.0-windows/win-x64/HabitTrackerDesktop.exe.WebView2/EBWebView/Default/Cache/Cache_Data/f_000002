function loadScheme() {
  const storedScheme = localStorage.getItem(SCHEME_KEY);
  return ["aurora", "sand", "graphite"].includes(storedScheme) ? storedScheme : "aurora";
}

function setTheme(theme) {
  state.theme = theme;
  localStorage.setItem(THEME_KEY, theme);
